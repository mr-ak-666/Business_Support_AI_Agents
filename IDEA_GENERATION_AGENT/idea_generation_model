# ----------------------------------------------------------------------
# 2.  Simple cost estimator (very rough – for illustration only)
# ----------------------------------------------------------------------
SECTOR_COST_MULTIPLIER = {
    "e‑commerce": 1.2,
    "SaaS": 0.9,
    "IoT": 1.5,
    "FinTech": 1.1,
    "On‑Demand": 1.0,
    "Renewables": 1.8,
    "Analytics": 1.3,
    "EdTech": 0.8,
    "Circular": 1.4,
    "Subscription": 0.7,
}

BASE_COST_INR = 5_00_000   # Base cost for a minimal MVP (₹5 Lakhs)

def estimate_cost(sector_tag: str, location: str) -> int:
    """
    Returns an estimated implementation cost in Indian Rupees (₹).
    The model is intentionally simplistic: base cost × sector multiplier.
    """
    multiplier = SECTOR_COST_MULTIPLIER.get(sector_tag, 1.0)

    # Adjust for location – metropolitan areas tend to be ~10% more expensive
    if location.lower() in {"mumbai", "delhi", "bangalore", "hyderabad", "chennai", "pune"}:
        location_factor = 1.10
    else:
        location_factor = 1.00

    estimated = int(BASE_COST_INR * multiplier * location_factor)
    # Round to nearest 10,000 for readability
    return round(estimated, -4)

# ----------------------------------------------------------------------
# 3.  Generate ideas based on user input
# ----------------------------------------------------------------------
def generate_ideas(sector: str, location: str, max_budget: int = None):
    """
    Returns a list of dictionaries, each containing:
        - title
        - description
        - estimated_cost (₹)
        - rollout_plan (list of 4 milestones)
    """
    ideas = []
    random.shuffle(IDEA_TEMPLATES)   # Randomise order each run

    for tmpl in IDEA_TEMPLATES[:10]:   # We need exactly 10 ideas
        title = tmpl["title"].format(sector=sector.title())
        desc = tmpl["desc"].format(sector=sector.lower(), location=location.title())
        cost = estimate_cost(tmpl["sector_tag"], location)

        # If user supplied a budget, skip ideas that exceed it
        if max_budget is not None and cost > max_budget:
            continue

        rollout = [
            "Month 1‑2: Market research & requirement gathering",
            "Month 2‑3: MVP design & core development",
            "Month 4‑5: Pilot testing with early adopters",
            "Month 5‑6: Full launch & first‑month marketing push"
        ]

        ideas.append({
            "title": title,
            "description": desc,
            "estimated_cost": cost,
            "rollout_plan": rollout
        })

        if len(ideas) == 10:
            break

    return ideas

# ----------------------------------------------------------------------
# 4.  Pretty‑print helper
# ----------------------------------------------------------------------
def print_output(ideas):
    if not ideas:
        print("\n⚠️ No ideas could be generated with the given constraints.\n")
        return

    table = []
    for idx, idea in enumerate(ideas, start=1):
        rollout_str = "\n".join(idea["rollout_plan"])
        table.append([
            idx,
            idea["title"],
            idea["description"],
            f"₹{idea['estimated_cost']:,}",
            rollout_str
        ])

    headers = ["#", "Idea Title", "Description", "Est. Cost (₹)", "6‑Month Rollout"]
    if HAVE_TABULATE:
        print("\n" + tabulate(table, headers=headers, tablefmt="github") + "\n")
    else:
        # Simple fallback
        col_widths = [max(len(str(row[i])) for row in table + [headers]) for i in range(len(headers))]
        fmt = " | ".join(f"{{:<{w}}}" for w in col_widths)
        separator = "-+-".join("-" * w for w in col_widths)

        print(fmt.format(*headers))
        print(separator)
        for row in table:
            print(fmt.format(*row))

# ----------------------------------------------------------------------
# 5.  Main interactive flow
# ----------------------------------------------------------------------
def main():
    print("\n=== 6‑Month Business Idea Generator (₹ Estimates) ===\n")
    sector = input("Enter the target sector (e.g., Agriculture, FinTech, Healthcare): ").strip()
    if not sector:
        print("❌ Sector is required. Exiting.")
        sys.exit(1)

    location = input("Enter the target location (city/state or 'India‑wide'): ").strip()
    if not location:
        print("❌ Location is required. Exiting.")
        sys.exit(1)

    budget_input = input("Maximum budget in ₹ (press Enter to skip): ").strip()
    max_budget = None
    if budget_input:
        try:
            max_budget = int(budget_input.replace(",", ""))
        except ValueError:
            print("⚠️ Invalid budget entered – ignoring budget constraint.")

    ideas = generate_ideas(sector, location, max_budget)

    print_output(ideas)

if __name__ == "__main__":
    main()
